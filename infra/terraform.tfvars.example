# ============================================================
# terraform.tfvars.example
# ============================================================
# Copy to terraform.tfvars and fill in your values.
# This file MUST NOT be committed to git (add terraform.tfvars to .gitignore).
# ============================================================

# ─────────────────────────────────────────────
# AWS Networking (get from your AWS VPC console)
# ─────────────────────────────────────────────
aws_region = "me-central-1"
vpc_id     = "vpc-xxxxxxxxxxxxxxxxx"

# Private subnets: where ECS tasks and RDS run (no direct internet access)
private_subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]

# Public subnets: where ALB lives (only needed if enable_alb = true)
public_subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]

# ─────────────────────────────────────────────
# RDS PostgreSQL
# ─────────────────────────────────────────────
db_instance_class    = "db.t3.micro"   # db.t3.small for production
db_name              = "agent_db"
db_username          = "agent_admin"
db_password          = "CHANGE_ME_strong_random_password"  # min 8 chars
db_allocated_storage = 20    # GB; auto-scales up to 100 GB
db_multi_az          = false # true for production HA

# ─────────────────────────────────────────────
# Application secrets
# ─────────────────────────────────────────────

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
secret_encryption_key = "CHANGE_ME_fernet_key_here="

# Generate: openssl rand -hex 32
jwt_secret_key = "CHANGE_ME_jwt_secret_here"

# Public URL of the deployed application (used for webhook URLs)
app_url = "https://your-domain.com"

# ─────────────────────────────────────────────
# ALB / HTTPS
# ─────────────────────────────────────────────
enable_alb      = true
certificate_arn = "arn:aws:acm:me-central-1:ACCOUNT_ID:certificate/YOUR_CERT_ID"

# ─────────────────────────────────────────────
# ECS sizing
# ─────────────────────────────────────────────
ecs_cpu           = 512   # 0.5 vCPU
ecs_memory        = 1024  # 1 GB RAM
ecs_desired_count = 1
