# ============================================================
# AI Agent CRM — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# Empty values mean the feature is disabled or has a safe default.
#
# Railway deployment: set these in the Railway service variables UI.
# AWS deployment: set these in ECS task definition / Secrets Manager.
# ============================================================


# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
ENVIRONMENT=development           # development | production
DEBUG=false                       # true only for local dev (enables auth bypass)
APP_URL=https://your-domain.com   # Public base URL, no trailing slash. Required for webhook URLs.

# CORS — comma-separated origins or * for wildcard
CORS_ORIGINS=http://localhost:3000


# ─────────────────────────────────────────────
# Database — PostgreSQL (primary backend)
# ─────────────────────────────────────────────
DATABASE_BACKEND=postgres         # postgres | dynamodb

# Railway: DATABASE_URL is injected automatically when you attach a Postgres plugin.
# AWS:     set to your RDS connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/agent_db

# Optional: separate public URL for migrations (Railway only)
# DATABASE_PUBLIC_URL=postgresql://user:password@public-host:5432/agent_db

# Fernet key for encrypting channel/notification tokens stored in Postgres.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED for postgres backend in production.
SECRET_ENCRYPTION_KEY=your-fernet-key-here


# ─────────────────────────────────────────────
# AWS (only needed if DATABASE_BACKEND=dynamodb
#       OR when deploying the app itself on AWS)
# ─────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# DynamoDB table names (only for dynamodb backend)
# DYNAMODB_TABLE_CONVERSATIONS=doctor-agent-conversations
# DYNAMODB_TABLE_MESSAGES=doctor-agent-messages
# DYNAMODB_TABLE_AGENTS=doctor-agent-agents
# DYNAMODB_TABLE_AUDIT_LOGS=doctor-agent-audit-logs
# DYNAMODB_TABLE_CHANNEL_BINDINGS=doctor-agent-channel-bindings
# DYNAMODB_TABLE_INSTAGRAM_PROFILES=doctor-agent-instagram-profiles
# DYNAMODB_TABLE_NOTIFICATION_CONFIGS=doctor-agent-notification-configs


# ─────────────────────────────────────────────
# LLM — OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # gpt-4o | gpt-4o-mini | gpt-4-turbo
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=600
OPENAI_TIMEOUT=30

# Embeddings (for RAG)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536


# ─────────────────────────────────────────────
# LLM — Google AI Studio (optional, for Gemini)
# ─────────────────────────────────────────────
# GOOGLE_AI_STUDIO_API=your-google-api-key


# ─────────────────────────────────────────────
# Redis (optional — used for caching)
# ─────────────────────────────────────────────
# Railway: REDIS_URL is injected automatically when you attach a Redis plugin.
# REDIS_URL=redis://localhost:6379/0

# Or use individual fields:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_SSL=false


# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# JWT — used for admin panel login. Generate a random 32+ char string.
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_EXPIRES_HOURS=8

# Comma-separated list of super-admin emails (optional)
# ALLOWED_ADMIN_EMAILS=admin@example.com,owner@example.com

# Static admin token (legacy / fallback). Prefer JWT in production.
# ADMIN_TOKEN=your-static-token-here

# Rate limiting
RATE_LIMIT_PER_MINUTE=60


# ─────────────────────────────────────────────
# Email — Resend (for OTP / notifications)
# ─────────────────────────────────────────────
# RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-domain.com
OTP_TTL_MINUTES=10
OTP_RATE_LIMIT=3


# ─────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────
# Choose storage backend: "cloudinary" (default, Railway) or "s3" (AWS)
STORAGE_BACKEND=cloudinary

# Cloudinary (STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=rag             # Base folder prefix in Cloudinary

# Amazon S3 (STORAGE_BACKEND=s3) — for AWS deployments
# S3_BUCKET_NAME=your-media-bucket-name
# S3_REGION=us-east-1             # Defaults to AWS_REGION if not set
# S3_PUBLIC_URL_PREFIX=           # Optional: CloudFront URL (e.g. https://d1234.cloudfront.net)
#                                 # Leave empty to use direct S3 HTTPS URL


# ─────────────────────────────────────────────
# Channel — Instagram
# ─────────────────────────────────────────────
# Token you set in Meta Developer Console → Webhooks → Verify Token
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-verify-token
# App Secret from Meta Developer Console → App Settings → Basic
# INSTAGRAM_APP_SECRET=your-app-secret


# ─────────────────────────────────────────────
# Channel — WhatsApp (Meta Cloud API)
# ─────────────────────────────────────────────
# Only needed as env var fallback; can also be configured via the admin UI.
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# WHATSAPP_APP_SECRET=your-app-secret


# ─────────────────────────────────────────────
# Message TTL
# ─────────────────────────────────────────────
MESSAGE_TTL_HOURS=48


# ─────────────────────────────────────────────
# WebSocket tuning
# ─────────────────────────────────────────────
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=5
